    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "378a3fdb-2c2d-4f10-9f7d-e3017d5b7890",
              "leftValue": "={{$json.outputs?.count || $json.processed_count || ($json.papers ? $json.papers.length : 0)}}",
