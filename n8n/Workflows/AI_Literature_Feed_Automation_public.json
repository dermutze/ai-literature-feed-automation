      "id": "e08e1759-322e-42eb-b715-5916e237efc1",
      "name": "Papers found"
    },
    {
      "parameters": {
        "jsCode": "const summary =\n  $json.text ||\n  $json.output ||\n  $json.response ||\n  \"No summary generated.\";\n\nconst previous = $(\"Papers selection\").first().json;\nconst o = previous.outputs || {};\n\nconst totalCount =\n  o.count ??\n  previous.processed_count ??\n  previous.raw_count ??\n  \"the selected\";\n\nconst summarizedCount = previous.papers ? previous.papers.length : 0;\n\nconst htmlSummary = summary\n  .replace(/\\n/g, \"<br>\")\n  .replace(/\\*\\*(.*?)\\*\\*/g, \"<strong>$1</strong>\");\n\nconst html = `\n<h2>🔬 AI Literature Feed Digest</h2>\n\n<p>\n<strong>${totalCount}</strong> relevant papers were identified.\n</p>\n\n<p>\nThe complete dataset is attached as BibTeX/RIS exports together with the generated markdown digest.\n</p>\n\n<p>\nThe top <strong>${summarizedCount}</strong> ranked papers are summarized below.\n</p>\n\n<hr>\n\n<div style=\"\nfont-family: Arial, sans-serif;\nline-height: 1.7;\nfont-size: 15px;\n\">\n${htmlSummary}\n</div>\n\n<hr>\n\n<p style=\"font-size:12px;color:#666;\">\nAutomatically generated using the AI-assisted literature monitoring pipeline.\n</p>\n`;\n\nreturn [{\n  json: {\n    subject: \"AI Literature Feed Digest\",\n    html\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -608,
        224
      ],
      "id": "afd24235-2c2c-4cd9-b397-127bb9419745",
      "name": "Prepare Message"
    },
    {
      "parameters": {
        "fromEmail": "your_email@example.com",
        "toEmail": "recipient@example.com",
        "subject": "={{$json.subject}}",
        "html": "={{$json.html}}",
        "options": {
          "appendAttribution": false,
          "attachments": "attachment_1,attachment_2,attachment_3"
        }
      },
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        368,
        336
      ],
      "id": "2603c51b-1bce-4c69-a078-47f6bdc13062",
      "name": "Send an Email"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are my scientific research assistant specialized in:\n- SiOC\n- polymer-derived ceramics (PDCs)\n- lithium-ion batteries\n- sodium-ion batteries\n- battery anodes\n- electrochemical energy storage materials\n\nYou will receive paper metadata and abstracts.\n\nUse ONLY the provided information.\nDo not invent mechanisms, electrochemical results, conductivity effects, synthesis details, cycling stability claims, or performance improvements unless they are explicitly stated.\n\nFor each selected paper, use exactly this format:\n\nPaper X\nTitle:\nAuthors:\nJournal:\nYear:\nDOI:\nURL:\n\nRelevance: XX/100 | Battery: High/Medium/Low | SiOC/PDC: High/Medium/Low\nMatched keywords:\n\nSummary:\n[Write 1–3 concise scientific sentences.]\n\nRules:\n- Keep the language scientific, concise, and professional.\n- Do not add bullet points.\n- Do not add extra sections or headings.\n- Do not write:\n  - \"The scientific contribution lies in...\"\n  - \"No specific information is provided.\"\n  - vague claims such as \"improved performance\" unless the improvement is explicitly stated.\n- Use only facts supported by the provided metadata or abstract.\n- If only the title is informative, summarize cautiously without hallucinating details.\n- For review papers, explicitly state that the paper is a review.\n- Preserve chemical formulas in compact scientific notation:\n  - Mo4.8Si3C0.6/MoC/SiOC\n  - Si/SiOC\n  - SiCN\n  - Li-ion\n- Keep summaries compact and readable for rapid literature triage.\n- Do not write an introduction or conclusion sentence.\n\nPapers:\n\n{{$json.top_papers_text}}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        144,
        0
      ],
      "id": "6cb232e1-8a67-4e71-8c99-6855776a1e65",
      "name": "Basic LLM Chain"
    },
    {
      "parameters": {
        "model": "llama3.2:3b",
        "options": {
          "temperature": 0.1,
          "topP": 0.8
        },
        "baseUrl": "http://host.docker.internal:11434"
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        480,
        112
      ],
      "id": "b5d8859c-feaa-453c-b57b-17e44552d9a5",
      "name": "Ollama Chat Model"
    },
    {
      "parameters": {
        "jsCode": "const outputs = $json.outputs;\nconst papersRaw = $json.papers || [];\n\nconst papers = papersRaw\n  .filter(p => {\n\n    const text =\n      `${p.title || \"\"} ${p.abstract || \"\"}`.toLowerCase();\n\n    const isSiOC =\n      text.includes(\"sioc\") ||\n      text.includes(\"silicon oxycarbide\") ||\n      text.includes(\"polymer-derived\") ||\n      text.includes(\"polymer derived\");\n\n    const isBattery =\n      text.includes(\"battery\") ||\n      text.includes(\"anode\") ||\n      text.includes(\"lithium\") ||\n      text.includes(\"sodium\") ||\n      text.includes(\"electrochemical\") ||\n      text.includes(\"capacity\") ||\n      text.includes(\"cycling\");\n\n    return isSiOC && isBattery;\n  })\n  .slice(0, 5);\n\nconst topPapersText = papers.map((p, i) => `\n\nPaper ${i + 1}\n\nTitle:\n${p.title || \"Untitled\"}\n\nAuthors:\n${(p.authors || []).join(\", \")}\n\nJournal:\n${p.journal || p.source || \"Unknown\"}\n\nYear:\n${p.year || \"\"}\n\nDOI:\n${p.doi || \"No DOI\"}\n\nURL:\n${p.url || \"\"}\n\nRelevance score:\n${p.relevance_score || \"\"}\n\nBattery relevance:\n${p.battery_relevance || \"\"}\n\nSiOC/PDC relevance:\n${p.sioc_pdc_relevance || \"\"}\n\nAbstract:\n${p.abstract || \"No abstract available\"}\n\n`).join(\"\\n\");\n\nreturn [{\n  json: {\n    outputs,\n    papers,\n    top_papers_text: topPapersText\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
